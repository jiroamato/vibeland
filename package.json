{
  "name": "minecraft-clone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vibeland - a from-scratch voxel sandbox game inspired by Minecraft (Java Edition), built with TypeScript + Three.js + Vite.",
  "scripts": {
